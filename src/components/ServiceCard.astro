---
import type { Service } from '../data/services';
export interface Props {
  service: Service;
  index?: number;
}
const { service, index = 0 } = Astro.props;
const lazy = index > 2;
---

<article id={`service-${service.slug}`} class="card group overflow-hidden scroll-mt-header transition-all duration-300 hover:-translate-y-1 hover:ring-emerald/40 hover:shadow-[0_18px_50px_-12px_rgba(16,185,129,0.40)]">
  <div class="aspect-[4/3] overflow-hidden bg-surface">
    <img
      src={service.image}
      alt={service.title}
      loading={lazy ? 'lazy' : 'eager'}
      decoding="async"
      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
      width="600"
      height="450"
    />
  </div>
  <div class="p-6">
    <h3 class="text-lg font-semibold text-ink-950">{service.title}</h3>
    <p class="mt-2 text-sm text-slate-text leading-relaxed">{service.short}</p>
    <a href={`/services/${service.slug}`} class="mt-4 inline-flex items-center gap-1 text-xs font-semibold text-emerald hover:text-emerald-light transition">
      Leistung ansehen
      <svg class="h-3 w-3 transition group-hover:translate-x-0.5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
    </a>
  </div>
</article>
