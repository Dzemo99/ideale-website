---
import { site } from '../../data/site';
---

<section class="relative overflow-hidden isolate">
  <div class="absolute inset-0 bg-[linear-gradient(180deg,#2a4a6c_0%,#4a6a8c_100%)] pointer-events-none" aria-hidden="true"></div>
  <div class="absolute inset-0 bg-hero-glow pointer-events-none" aria-hidden="true"></div>
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_-10%,rgba(16,185,129,0.15),transparent_60%)] pointer-events-none" aria-hidden="true"></div>

  <div class="container-x relative pt-16 pb-24 lg:pt-24 lg:pb-32">
    <div class="grid grid-cols-1 lg:grid-cols-12 lg:gap-12 items-start">
      <div class="lg:col-span-7 lg:pr-8">
        <div class="inline-flex items-center gap-2 rounded-full bg-emerald/10 px-3.5 py-1.5 ring-1 ring-emerald/20 mb-6">
          <span class="h-1.5 w-1.5 rounded-full bg-emerald animate-pulse"></span>
          <span class="text-xs font-medium text-emerald">{site.claim}</span>
        </div>

        <h1 class="h1-hero text-white text-balance">
          Sauberkeit in <span class="text-white">Ihrem Ort</span> –<br class="hidden sm:block" />
          schnell, gründlich, fair.
        </h1>

        <p class="mt-6 text-lg text-white/70 max-w-xl leading-relaxed">
          Wir reinigen Büros, Praxen, Wohnungen und Gewerbeobjekte deutschlandweit.
          Mit geschultem Personal, modernem Equipment und fairen Festpreisen.
        </p>

        <div class="mt-9 flex flex-wrap gap-3">
          <a href="#kontakt-rechner" class="btn-primary">
            Sofort-Angebot erhalten
            <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
          </a>
          <a href="#services" class="btn-secondary">Leistungen ansehen</a>
        </div>

        <dl class="mt-12 grid grid-cols-3 gap-6 max-w-md">
          <div>
            <dt class="text-xs font-medium uppercase tracking-wider text-white/40">Qualität</dt>
            <dd class="mt-1 text-2xl font-bold text-white">100%</dd>
            <dd class="text-xs text-white/50">Kontrolle</dd>
          </div>
          <div>
            <dt class="text-xs font-medium uppercase tracking-wider text-white/40">Verfügbar</dt>
            <dd class="mt-1 text-2xl font-bold text-white">24/7</dd>
            <dd class="text-xs text-white/50">erreichbar</dd>
          </div>
          <div>
            <dt class="text-xs font-medium uppercase tracking-wider text-white/40">Region</dt>
            <dd class="mt-1 text-2xl font-bold text-white">DE</dd>
            <dd class="text-xs text-white/50">deutschlandweit</dd>
          </div>
        </dl>
      </div>

      <div class="lg:col-span-5 mt-12 lg:mt-0">
        <form
          name="hauptseite-quick"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          action="/danke"
          class="relative rounded-3xl bg-white/[0.04] backdrop-blur-xl ring-1 ring-white/10 p-6 sm:p-8 shadow-2xl"
        >
          <input type="hidden" name="form-name" value="hauptseite-quick" />
          <p class="hidden">
            <label>Bot Feld: <input name="bot-field" /></label>
          </p>

          <div class="absolute -top-3 -right-3 rounded-full bg-emerald px-3 py-1 text-[10px] font-bold uppercase tracking-wider text-white shadow-lg">
            Schnellanfrage
          </div>

          <h2 class="text-xl font-bold text-white">Kostenloses Angebot</h2>
          <p class="mt-1 text-sm text-white/60">Antwort innerhalb von 24 h.</p>

          <div class="mt-5 space-y-3">
            <div>
              <label for="q-name" class="sr-only">Name</label>
              <input id="q-name" type="text" name="name" required placeholder="Ihr Name *" class="input-dark" autocomplete="name" />
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              <input type="email" name="email" required placeholder="E-Mail *" class="input-dark" autocomplete="email" aria-label="E-Mail" />
              <input type="tel" name="phone" placeholder="Telefon" class="input-dark" autocomplete="tel" aria-label="Telefon" />
            </div>
            <div>
              <label for="q-msg" class="sr-only">Nachricht</label>
              <textarea id="q-msg" name="message" rows="3" placeholder="Was möchten Sie reinigen lassen?" class="input-dark resize-none"></textarea>
            </div>
            <div class="flex items-start gap-2">
              <input id="q-consent" type="checkbox" name="consent" required class="mt-1 h-4 w-4 rounded accent-emerald" />
              <label for="q-consent" class="text-xs text-white/60">
                Ich stimme der Verarbeitung meiner Daten gemäß <a href="/datenschutz" class="text-emerald hover:underline">Datenschutz</a> zu.
              </label>
            </div>
            <button type="submit" class="btn-primary w-full" data-track="form-quick">
              Angebot anfragen
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  document.querySelectorAll('form[name="hauptseite-quick"]').forEach(function (f) {
    f.addEventListener('submit', function () {
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({ event: 'form_submit', form_name: 'hauptseite-quick', value: 80 });
    });
  });
</script>
