---
const items = [
  {
    title: 'Schnell & Zuverlässig',
    body: 'Wir reagieren auf Anfragen innerhalb von 24 Stunden und halten unsere Termine. Pünktlichkeit ist kein Bonus – sondern Pflicht.',
    icon: 'M13 10V3L4 14h7v7l9-11h-7z',
  },
  {
    title: 'Gründlich & Professionell',
    body: 'Geschultes Personal, modernes Equipment und systematische Qualitätskontrolle. Jeder Auftrag wird abgenommen.',
    icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  {
    title: 'Fair & Transparent',
    body: 'Festpreise ohne versteckte Kosten. Sie wissen vor Beginn, was Sie zahlen. Keine Überraschungen, kein Kleingedrucktes.',
    icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  },
];
---

<section class="bg-surface light-section py-24 lg:py-32">
  <div class="container-x">
    <div class="max-w-3xl">
      <span class="inline-flex items-center gap-2 rounded-full bg-emerald/10 px-3.5 py-1.5 text-xs font-medium text-emerald-dark ring-1 ring-emerald/20">
        Warum Ideale
      </span>
      <h2 class="mt-5 h2-section text-balance">
        Drei Versprechen, die wir jeden Tag einlösen.
      </h2>
      <p class="mt-5 text-lg text-ink-700/70 max-w-2xl leading-relaxed">
        Sauberkeit ist Vertrauenssache. Wir verdienen uns Ihr Vertrauen durch Konsequenz.
      </p>
    </div>

    <div class="mt-14 grid grid-cols-1 md:grid-cols-3 gap-6">
      {items.map((item) => (
        <article class="rounded-2xl bg-white p-8 ring-1 ring-ink-950/5 shadow-sm transition hover:shadow-lg hover:-translate-y-1">
          <div class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-emerald/10 text-emerald">
            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d={item.icon} /></svg>
          </div>
          <h3 class="mt-5 text-lg font-semibold text-ink-950">{item.title}</h3>
          <p class="mt-2 text-sm text-ink-700/70 leading-relaxed">{item.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>
