---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaBanner from '../components/sections/CtaBanner.astro';
import Bewertungen from '../components/sections/Bewertungen.astro';
import { site } from '../data/site';
---

<BaseLayout
  title={`Kundenbewertungen – ${site.name}`}
  description="Was unsere B2B-Kunden über Ideale Gebäudereinigung sagen. Echte Stimmen aus Autohäusern, Hausverwaltungen und Gewerbebau."
>
  <section class="relative bg-surface py-20 lg:py-28">
    <div class="container-x relative">
      <span class="badge-emerald">Bewertungen</span>
      <h1 class="mt-5 h1-hero text-ink-950 text-balance max-w-3xl">
        Was unsere <span class="text-emerald">B2B-Kunden</span> sagen.
      </h1>
      <p class="mt-6 text-lg text-slate-text max-w-2xl">
        Mehr als gut gemeinte Marketing-Sätze: Echte Stimmen aus laufenden Wartungsverträgen
        mit Autohäusern, Hausverwaltungen und Gewerbebau.
      </p>
    </div>
  </section>

  <Bewertungen heading={false} />

  <section class="bg-white pb-20 lg:pb-28">
    <div class="container-x">
      <p class="text-center text-xs text-slate-mute">
        Sie sind Kunde und möchten ebenfalls eine Bewertung abgeben? Schreiben Sie uns an
        <a href={`mailto:${site.email}`} class="text-emerald hover:underline font-medium">{site.email}</a>.
      </p>
    </div>
  </section>

  <CtaBanner />
</BaseLayout>
