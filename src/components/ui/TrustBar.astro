---
const items = [
  {
    title: '5 Mio. € Absicherung',
    subtitle: 'Gewerbliche Betriebshaftpflicht',
    icon: 'shield',
  },
  {
    title: 'Geprüftes Team',
    subtitle: 'Geschulte & feste Reinigungskräfte',
    icon: 'badge',
  },
  {
    title: '100% Rechtssicher',
    subtitle: 'Garantierte DSGVO-Konformität',
    icon: 'lock',
  },
  {
    title: 'Ideale Fixzeit',
    subtitle: 'Pünktlich & zuverlässig vor Ort',
    icon: 'clock',
  },
];
---

<section class="bg-surface border-y border-slate-border">
  <div class="container-x py-10 lg:py-14">
    <ul class="grid grid-cols-2 lg:grid-cols-4 gap-x-6 gap-y-8 lg:gap-x-10">
      {items.map((item) => (
        <li class="flex items-start gap-3 sm:gap-4 min-h-[56px]">
          <span class="shrink-0 inline-flex h-10 w-10 items-center justify-center rounded-xl bg-emerald-50 ring-1 ring-emerald-50" aria-hidden="true">
            {item.icon === 'shield' && (
              <svg class="h-5 w-5 text-emerald-dark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                <path d="m9 12 2 2 4-4" />
              </svg>
            )}
            {item.icon === 'badge' && (
              <svg class="h-5 w-5 text-emerald-dark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3.85 8.62a4 4 0 0 1 4.78-4.77 4 4 0 0 1 6.74 0 4 4 0 0 1 4.78 4.78 4 4 0 0 1 0 6.74 4 4 0 0 1-4.77 4.78 4 4 0 0 1-6.75 0 4 4 0 0 1-4.78-4.77 4 4 0 0 1 0-6.76Z" />
                <path d="m9 12 2 2 4-4" />
              </svg>
            )}
            {item.icon === 'lock' && (
              <svg class="h-5 w-5 text-emerald-dark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="11" width="18" height="11" rx="2" />
                <path d="M7 11V7a5 5 0 0 1 10 0v4" />
              </svg>
            )}
            {item.icon === 'clock' && (
              <svg class="h-5 w-5 text-emerald-dark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10" />
                <polyline points="12 6 12 12 16 14" />
              </svg>
            )}
          </span>
          <div class="min-w-0">
            <p class="text-base sm:text-lg font-semibold text-ink-950 leading-tight tracking-tight">
              {item.title}
            </p>
            <p class="mt-1 text-sm text-slate-mute leading-snug">
              {item.subtitle}
            </p>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>
