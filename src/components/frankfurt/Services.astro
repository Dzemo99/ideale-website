---
import { frankfurtServices } from '../../data/frankfurt';
---

<section id="frankfurt-services" class="bg-surface py-24 lg:py-32 scroll-mt-header">
  <div class="container-x">
    <div class="max-w-3xl">
      <span class="badge-emerald">{frankfurtServices.length} Leistungen für Frankfurt</span>
      <h2 class="mt-5 h2-section text-ink-950 text-balance">
        Reinigungslösungen für<br/>
        <span class="text-emerald">Frankfurt am Main & Rhein-Main</span>.
      </h2>
      <p class="mt-5 text-lg text-slate-text max-w-2xl leading-relaxed">
        Vom Bankenviertel bis Sachsenhausen, von der Praxis bis zur Glasfassade –
        wir bieten alle gängigen Reinigungsleistungen im Großraum Frankfurt aus einer Hand.
      </p>
    </div>

    <div class="mt-14 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {frankfurtServices.map((s, i) => {
        const lazy = i > 2;
        return (
          <article id={`frankfurt-service-${s.slug}`} class="card group overflow-hidden scroll-mt-header transition-all duration-300 hover:-translate-y-1 hover:ring-emerald/40 hover:shadow-[0_18px_50px_-12px_rgba(16,185,129,0.40)]">
            {s.image && (
              <div class="aspect-[4/3] overflow-hidden bg-surface">
                <img
                  src={s.image}
                  alt={`${s.title} Frankfurt`}
                  loading={lazy ? 'lazy' : 'eager'}
                  decoding="async"
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                  width="600"
                  height="450"
                />
              </div>
            )}
            <div class="p-6">
              <h3 class="text-lg font-semibold text-ink-950">{s.title}</h3>
              <p class="mt-2 text-sm text-slate-text leading-relaxed">{s.short}</p>
              <a href="#frankfurt-kontakt" class="mt-4 inline-flex items-center gap-1 text-xs font-semibold text-emerald hover:text-emerald-light transition">
                Anfragen
                <svg class="h-3 w-3 transition group-hover:translate-x-0.5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
              </a>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>
