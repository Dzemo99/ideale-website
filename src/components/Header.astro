---
import { site } from '../data/site';
import { services } from '../data/services';
import Logo from './Logo.astro';

const navLinks = [
  { href: '/', label: 'Start' },
  { href: '/privat', label: 'Privat' },
  { href: '/gewerbe', label: 'Gewerbe' },
  { href: '/ablauf', label: 'Ablauf' },
  { href: '/bewertungen', label: 'Bewertungen' },
  { href: '/faq', label: 'FAQ' },
  { href: '/kontakt', label: 'Kontakt' },
];
---

<header
  id="site-header"
  data-scrolled="false"
  class="sticky top-0 z-40 w-full bg-surface transition-all duration-200"
>
  <div class="container-x flex h-16 items-center justify-between gap-4">
    <Logo />

    <nav class="hidden lg:flex items-center gap-7" aria-label="Hauptnavigation">
      {navLinks.slice(0, 3).map((l) => (
        <a href={l.href} class="text-sm font-medium text-ink-950 transition hover:text-emerald">
          {l.label}
        </a>
      ))}

      <div class="relative group">
        <button
          type="button"
          class="inline-flex items-center gap-1 text-sm font-medium text-ink-950 transition hover:text-emerald"
          aria-haspopup="true"
        >
          Leistungen
          <svg class="h-4 w-4 transition group-hover:rotate-180" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.06l3.71-3.83a.75.75 0 111.08 1.04l-4.25 4.39a.75.75 0 01-1.08 0L5.21 8.27a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
          </svg>
        </button>

        <div class="invisible absolute left-1/2 top-full -translate-x-1/2 pt-3 opacity-0 transition-all group-hover:visible group-hover:opacity-100">
          <div class="w-[680px] rounded-2xl bg-white p-3 ring-1 ring-slate-border shadow-card">
            <div class="grid grid-cols-2 gap-1">
              {services.map((s) => (
                <a
                  href={`/#service-${s.slug}`}
                  class="flex items-center gap-2 rounded-lg px-3 py-2 text-sm text-slate-text transition hover:bg-surface hover:text-ink-950"
                >
                  <span class="h-1.5 w-1.5 rounded-full bg-emerald"></span>
                  {s.title}
                </a>
              ))}
            </div>
            <div class="mt-2 border-t border-slate-border px-3 py-2.5">
              <a href="/einsatzgebiete" class="text-xs font-semibold text-emerald hover:text-emerald-light">Einsatzgebiete →</a>
            </div>
          </div>
        </div>
      </div>

      {navLinks.slice(3).map((l) => (
        <a href={l.href} class="text-sm font-medium text-ink-950 transition hover:text-emerald">
          {l.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-2">
      <a
        href={`tel:${site.phoneE164}`}
        class="hidden md:inline-flex items-center gap-2 rounded-full bg-white px-3.5 py-2 text-xs font-semibold text-ink-950 ring-1 ring-slate-border transition hover:bg-surface"
        data-track="header-phone"
      >
        <svg class="h-3.5 w-3.5 text-emerald" viewBox="0 0 24 24" fill="currentColor"><path d="M20 15.5c-1.25 0-2.45-.2-3.57-.57a1 1 0 00-1.01.24l-2.2 2.2a15.05 15.05 0 01-6.59-6.59l2.2-2.21a1 1 0 00.25-1A11.36 11.36 0 018.5 4a1 1 0 00-1-1H4a1 1 0 00-1 1 17 17 0 0017 17 1 1 0 001-1v-3.5a1 1 0 00-1-1z"/></svg>
        {site.phone}
      </a>
      <a href="/kontakt" class="hidden sm:inline-flex btn-primary !px-4 !py-2.5 !text-xs">
        Angebot anfragen
      </a>

      <button
        id="mobile-menu-toggle"
        type="button"
        class="lg:hidden inline-flex h-10 w-10 items-center justify-center rounded-lg bg-white ring-1 ring-slate-border"
        aria-label="Menü öffnen"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg class="h-5 w-5 text-ink-950" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="lg:hidden hidden border-t border-slate-border bg-white">
    <nav class="container-x flex flex-col gap-1 py-4" aria-label="Mobile Navigation">
      {navLinks.map((l) => (
        <a href={l.href} class="rounded-lg px-3 py-2.5 text-sm font-medium text-ink-950 hover:bg-surface hover:text-emerald">
          {l.label}
        </a>
      ))}
      <details class="group">
        <summary class="flex cursor-pointer list-none items-center justify-between rounded-lg px-3 py-2.5 text-sm font-medium text-ink-950 hover:bg-surface">
          Leistungen
          <svg class="h-4 w-4 transition group-open:rotate-180" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.06l3.71-3.83a.75.75 0 111.08 1.04l-4.25 4.39a.75.75 0 01-1.08 0L5.21 8.27a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
          </svg>
        </summary>
        <div class="mt-1 ml-3 flex flex-col gap-0.5 border-l border-slate-border pl-3">
          {services.map((s) => (
            <a href={`/#service-${s.slug}`} class="rounded-lg px-3 py-2 text-sm text-slate-text hover:bg-surface hover:text-ink-950">
              {s.title}
            </a>
          ))}
          <a href="/einsatzgebiete" class="rounded-lg px-3 py-2 text-sm font-semibold text-emerald">Einsatzgebiete →</a>
        </div>
      </details>
      <a href={`tel:${site.phoneE164}`} class="mt-3 btn-secondary !w-full">
        {site.phone}
      </a>
      <a href="/kontakt" class="btn-primary !w-full">Angebot anfragen</a>
    </nav>
  </div>
</header>

<script is:inline>
  (function () {
    var header = document.getElementById('site-header');
    var toggle = document.getElementById('mobile-menu-toggle');
    var menu = document.getElementById('mobile-menu');

    if (header) {
      var THRESHOLD = 50;
      var apply = function () {
        var scrolled = window.scrollY > THRESHOLD;
        header.dataset.scrolled = scrolled ? 'true' : 'false';
        header.classList.toggle('bg-white/95', scrolled);
        header.classList.toggle('backdrop-blur-md', scrolled);
        header.classList.toggle('border-b', scrolled);
        header.classList.toggle('border-slate-border', scrolled);
        header.classList.toggle('shadow-header', scrolled);
        header.classList.toggle('bg-surface', !scrolled);
      };
      window.addEventListener('scroll', apply, { passive: true });
      apply();
    }

    if (toggle && menu) {
      toggle.addEventListener('click', function () {
        var open = !menu.classList.contains('hidden');
        if (open) {
          menu.classList.add('hidden');
          toggle.setAttribute('aria-expanded', 'false');
        } else {
          menu.classList.remove('hidden');
          toggle.setAttribute('aria-expanded', 'true');
        }
      });
    }

    // phone_click tracking is handled globally via delegated listener in BaseLayout
  })();
</script>
