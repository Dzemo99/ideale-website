---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';
const waMsg = encodeURIComponent('Hallo, ich interessiere mich für eine Reinigung.');
---

<BaseLayout
  title={`Kontakt – ${site.name}`}
  description={`Kontaktieren Sie ${site.name}: Telefon ${site.phone}, WhatsApp, E-Mail oder Formular. Antwort innerhalb von 24 Stunden.`}
>
  <section class="relative bg-ink-950 py-20 lg:py-28">
    <div class="absolute inset-0 bg-hero-glow pointer-events-none" aria-hidden="true"></div>
    <div class="container-x relative">
      <span class="badge-emerald">Kontakt</span>
      <h1 class="mt-5 h1-hero text-white text-balance max-w-3xl">
        Wir <span class="text-emerald">freuen uns</span> auf Ihre Anfrage.
      </h1>
      <p class="mt-6 text-lg text-white/70 max-w-2xl">
        Schreiben Sie uns oder rufen Sie an. Wir sind 24/7 erreichbar und antworten auf schriftliche Anfragen innerhalb von 24 Stunden.
      </p>
    </div>
  </section>

  <section class="bg-ink-900 py-20 lg:py-28">
    <div class="container-x">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
        <div class="lg:col-span-5 space-y-5">
          <a
            href={`tel:${site.phoneE164}`}
            class="flex items-start gap-4 rounded-2xl bg-ink-950/60 p-6 ring-1 ring-white/5 transition hover:ring-emerald/30 hover:-translate-y-0.5"
          >
            <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-xl bg-emerald/15 text-emerald">
              <svg class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor"><path d="M20 15.5c-1.25 0-2.45-.2-3.57-.57a1 1 0 00-1.01.24l-2.2 2.2a15.05 15.05 0 01-6.59-6.59l2.2-2.21a1 1 0 00.25-1A11.36 11.36 0 018.5 4a1 1 0 00-1-1H4a1 1 0 00-1 1 17 17 0 0017 17 1 1 0 001-1v-3.5a1 1 0 00-1-1z"/></svg>
            </div>
            <div>
              <div class="text-xs font-medium uppercase tracking-wider text-white/40">Telefon</div>
              <div class="mt-1 text-lg font-semibold text-white">{site.phone}</div>
              <div class="text-xs text-white/50">Mo-So, 24/7 erreichbar</div>
            </div>
          </a>

          <a
            href={`https://wa.me/${site.whatsappE164.replace('+', '')}?text=${waMsg}`}
            target="_blank"
            rel="noopener"
            class="flex items-start gap-4 rounded-2xl bg-ink-950/60 p-6 ring-1 ring-white/5 transition hover:ring-emerald/30 hover:-translate-y-0.5"
          >
            <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-xl bg-[#25D366]/15 text-[#25D366]">
              <svg class="h-6 w-6" viewBox="0 0 32 32" fill="currentColor"><path d="M16 0C7.17 0 0 7.17 0 16c0 2.81.73 5.54 2.12 7.95L0 32l8.27-2.16A15.93 15.93 0 0016 32c8.83 0 16-7.17 16-16S24.83 0 16 0z"/></svg>
            </div>
            <div>
              <div class="text-xs font-medium uppercase tracking-wider text-white/40">WhatsApp</div>
              <div class="mt-1 text-lg font-semibold text-white">{site.whatsapp}</div>
              <div class="text-xs text-white/50">Schnellste Antwort</div>
            </div>
          </a>

          <a
            href={`mailto:${site.email}`}
            class="flex items-start gap-4 rounded-2xl bg-ink-950/60 p-6 ring-1 ring-white/5 transition hover:ring-emerald/30 hover:-translate-y-0.5"
          >
            <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-xl bg-emerald/15 text-emerald">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
            </div>
            <div>
              <div class="text-xs font-medium uppercase tracking-wider text-white/40">E-Mail</div>
              <div class="mt-1 text-base font-semibold text-white break-all">{site.email}</div>
              <div class="text-xs text-white/50">Antwort binnen 24 h</div>
            </div>
          </a>

          <div class="rounded-2xl bg-ink-950/60 p-6 ring-1 ring-white/5">
            <div class="text-xs font-medium uppercase tracking-wider text-white/40">Adresse</div>
            <address class="mt-1 not-italic text-base text-white">
              {site.legalName}<br/>
              {site.street}<br/>
              {site.zip} {site.city}
            </address>
            <div class="mt-3 aspect-[16/9] rounded-xl bg-ink-800 ring-1 ring-white/5 overflow-hidden">
              <!-- TODO Dzemo: Echte Karte einbinden (Google Maps Embed oder OpenStreetMap iframe). -->
              <div class="flex h-full items-center justify-center text-xs text-white/30">
                Karte folgt
              </div>
            </div>
          </div>
        </div>

        <div class="lg:col-span-7">
          <form
            name="hauptseite-kontakt"
            method="POST"
            data-netlify="true"
            netlify-honeypot="bot-field"
            action="/danke"
            class="rounded-3xl bg-white/[0.04] backdrop-blur-xl ring-1 ring-white/10 p-7 sm:p-9 shadow-2xl"
          >
            <input type="hidden" name="form-name" value="hauptseite-kontakt" />
            <p class="hidden"><label>Bot Feld: <input name="bot-field" /></label></p>

            <h2 class="text-xl font-bold text-white">Nachricht senden</h2>
            <p class="mt-1 text-sm text-white/60">Wir melden uns innerhalb von 24 Stunden.</p>

            <div class="mt-6 grid grid-cols-1 sm:grid-cols-2 gap-3">
              <input name="name" type="text" required placeholder="Vor- und Nachname *" class="input-dark sm:col-span-2" autocomplete="name" aria-label="Name" />
              <input name="company" type="text" placeholder="Firma (optional)" class="input-dark" aria-label="Firma" />
              <input name="phone" type="tel" required placeholder="Telefon *" class="input-dark" autocomplete="tel" aria-label="Telefon" />
              <input name="email" type="email" required placeholder="E-Mail *" class="input-dark sm:col-span-2" autocomplete="email" aria-label="E-Mail" />
              <select name="leistung" class="input-dark sm:col-span-2" aria-label="Gewünschte Leistung">
                <option value="">Gewünschte Leistung wählen…</option>
                <option>Büroreinigung</option>
                <option>Praxisreinigung</option>
                <option>Treppenhausreinigung</option>
                <option>Fensterreinigung</option>
                <option>Bauendreinigung</option>
                <option>Sonderreinigung</option>
                <option>Winterdienst</option>
                <option>Privat / Haushalt</option>
                <option>Andere</option>
              </select>
              <textarea name="message" rows="5" required placeholder="Ihre Nachricht *" class="input-dark sm:col-span-2 resize-none"></textarea>
            </div>

            <div class="mt-5 flex items-start gap-2">
              <input id="k-consent" type="checkbox" name="consent" required class="mt-1 h-4 w-4 rounded accent-emerald" />
              <label for="k-consent" class="text-xs text-white/60">
                Ich stimme der Verarbeitung meiner Daten gemäß <a href="/datenschutz" class="text-emerald hover:underline">Datenschutz</a> zu.
              </label>
            </div>

            <button type="submit" class="mt-6 btn-primary w-full" data-track="form-kontakt">
              Nachricht senden
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  document.querySelectorAll('form[name="hauptseite-kontakt"]').forEach(function (f) {
    f.addEventListener('submit', function () {
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({ event: 'form_submit', form_name: 'hauptseite-kontakt', value: 80 });
    });
  });
</script>
