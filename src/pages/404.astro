---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Seite nicht gefunden – Ideale Gebäudereinigung" description="Diese Seite konnte nicht gefunden werden." noindex>
  <section class="relative bg-ink-950 py-24 lg:py-32 min-h-[70vh] flex items-center">
    <div class="absolute inset-0 bg-hero-glow pointer-events-none" aria-hidden="true"></div>
    <div class="container-x relative text-center">
      <p class="text-7xl sm:text-9xl font-extrabold text-emerald/20 tracking-tightest">404</p>
      <h1 class="mt-2 h1-hero text-white">Seite nicht gefunden</h1>
      <p class="mt-5 text-lg text-white/70 max-w-md mx-auto">
        Die Seite, die Sie suchen, existiert nicht oder wurde verschoben.
      </p>
      <div class="mt-10 flex flex-wrap justify-center gap-3">
        <a href="/" class="btn-primary">Zur Startseite</a>
        <a href="/kontakt" class="btn-secondary">Kontakt aufnehmen</a>
      </div>
    </div>
  </section>
</BaseLayout>
