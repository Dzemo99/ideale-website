---
export interface Props {
  class?: string;
  variant?: 'light' | 'dark'; // light = on light bg, dark = on dark bg (footer)
}
const { class: className = '', variant = 'light' } = Astro.props;
const textPrimary = variant === 'dark' ? 'text-white' : 'text-ink-950';
const textSub = variant === 'dark' ? 'text-slate-on-navy' : 'text-slate-mute';
---

<a href="/" class={`group inline-flex items-center gap-2.5 ${className}`} aria-label="Ideale Gebäudereinigung Startseite">
  <span class="relative flex h-9 w-9 items-center justify-center rounded-xl bg-ink-950 shadow-soft transition-transform group-hover:scale-105">
    <span class="text-sm font-extrabold tracking-tight text-emerald">IG</span>
  </span>
  <span class="hidden sm:block leading-tight">
    <span class={`block text-[15px] font-bold tracking-tight ${textPrimary}`}>Ideale</span>
    <span class={`block text-[10px] font-medium uppercase tracking-[0.18em] ${textSub}`}>Gebäudereinigung</span>
  </span>
</a>
