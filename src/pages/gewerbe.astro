---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaBanner from '../components/sections/CtaBanner.astro';
import { site } from '../data/site';

const items = [
  { title: 'Büroreinigung', body: 'Saubere Schreibtische, gepflegte Sanitäranlagen, blitzblanke Konferenzräume.' },
  { title: 'Praxisreinigung', body: 'Hygiene nach RKI-Standards für Arzt- und Zahnarztpraxen.' },
  { title: 'Treppenhausreinigung', body: 'Hausverwaltungen und WEGs – regelmäßig zum Festpreis.' },
  { title: 'Industrie- und Lagerhallen', body: 'Bodenpflege, Maschinenreinigung, Grundreinigung.' },
  { title: 'Kitareinigung', body: 'Hautverträgliche Mittel, außerhalb der Betreuungszeiten.' },
  { title: 'Kanzleireinigung', body: 'Diskret, vertraulich, langjährig eingespieltes Personal.' },
  { title: 'Bauend- und Sonderreinigung', body: 'Nach Bau, Renovierung oder Wasserschaden.' },
  { title: 'Winterdienst', body: 'Räum- und Streupflicht zuverlässig erfüllt.' },
];
---

<BaseLayout
  title={`Reinigung für Gewerbe – ${site.name}`}
  description="Gewerbereinigung von Ideale Gebäudereinigung: Büro, Praxis, Treppenhaus, Industrie, Kita, Kanzlei, Bauend & mehr. Festpreise, Wartungsverträge, deutschlandweit."
>
  <section class="relative bg-surface py-20 lg:py-28">
    <div class="container-x relative">
      <span class="badge-emerald">Für Gewerbekunden</span>
      <h1 class="mt-5 h1-hero text-ink-950 text-balance max-w-3xl">
        Reinigung als <span class="text-emerald">verlässlicher Service-Partner.</span>
      </h1>
      <p class="mt-6 text-lg text-slate-text max-w-2xl">
        Saubere Büros, hygienische Praxen, gepflegte Eingangsbereiche. Mit Wartungsverträgen, Festpreisen und Ansprechpartnern, die Ihre Sprache sprechen.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/kontakt" class="btn-primary">Anfrage stellen</a>
        <a href={`tel:${site.phoneE164}`} class="btn-secondary">{site.phone}</a>
      </div>
    </div>
  </section>

  <section class="bg-white py-20 lg:py-28">
    <div class="container-x">
      <h2 class="h2-section text-ink-950 text-balance max-w-2xl">Unsere Leistungen für Gewerbekunden</h2>
      <div class="mt-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {items.map((i) => (
          <div class="card p-7">
            <div class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-emerald-50 text-emerald-dark">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            </div>
            <h3 class="mt-4 text-lg font-semibold text-ink-950">{i.title}</h3>
            <p class="mt-2 text-sm text-slate-text leading-relaxed">{i.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-surface py-20 lg:py-28">
    <div class="container-x">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <div>
          <h2 class="h2-section text-ink-950 text-balance">Warum sich Gewerbekunden für uns entscheiden</h2>
          <p class="mt-5 text-lg text-slate-text leading-relaxed">
            Wir denken in Wartungsverträgen, nicht in Einzeleinsätzen. Ein fester Ansprechpartner, klar definierte Leistung, transparente Abrechnung.
          </p>
        </div>
        <ul class="space-y-4">
          {[
            'Versicherung mit 5 Mio. EUR Deckungssumme',
            'Geschultes, festangestelltes Personal',
            'Qualitätskontrolle bei jedem Einsatz',
            'Reaktionszeit unter 24 Stunden',
            'Festpreise ohne versteckte Kosten',
            'Sammelrechnung und Zahlungsziel auf Wunsch',
          ].map((p) => (
            <li class="flex items-start gap-3">
              <span class="mt-0.5 flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full bg-emerald text-white">
                <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              </span>
              <span class="text-base text-slate-text">{p}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <CtaBanner />
</BaseLayout>
