---
import { site } from '../../data/site';
import { FRANKFURT_FORM_SERVICES } from '../../data/frankfurt';
---

<section id="frankfurt-kontakt" class="bg-white py-24 lg:py-32 scroll-mt-header">
  <div class="container-x">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">

      <div class="lg:col-span-5">
        <span class="badge-emerald">Direkt-Kontakt</span>
        <h2 class="mt-5 h2-section text-ink-950 text-balance">
          Schreiben Sie uns –<br/>
          <span class="text-emerald">wir melden uns binnen 24 h.</span>
        </h2>
        <p class="mt-5 text-lg text-slate-text leading-relaxed">
          Für ein verbindliches Angebot brauchen wir kurz ein paar Eckdaten zum Objekt in Frankfurt.
          Lieber telefonisch? Auch gut – wir sind erreichbar.
        </p>

        <div class="mt-8 space-y-4">
          <a href={`tel:${site.phoneE164}`} class="flex items-start gap-3 group" data-track="kontakt-phone-frankfurt">
            <div class="shrink-0 flex h-11 w-11 items-center justify-center rounded-xl bg-emerald-50 text-emerald-dark">
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor"><path d="M20 15.5c-1.25 0-2.45-.2-3.57-.57a1 1 0 00-1.01.24l-2.2 2.2a15.05 15.05 0 01-6.59-6.59l2.2-2.21a1 1 0 00.25-1A11.36 11.36 0 018.5 4a1 1 0 00-1-1H4a1 1 0 00-1 1 17 17 0 0017 17 1 1 0 001-1v-3.5a1 1 0 00-1-1z"/></svg>
            </div>
            <div>
              <div class="text-xs font-medium uppercase tracking-wider text-slate-mute">Telefon</div>
              <div class="text-lg font-semibold text-ink-950 group-hover:text-emerald transition">{site.phone}</div>
            </div>
          </a>

          <a href={`https://wa.me/${site.whatsappE164.replace('+', '')}?text=Hallo%2C%20ich%20interessiere%20mich%20f%C3%BCr%20Reinigung%20in%20Frankfurt.`} target="_blank" rel="noopener" class="flex items-start gap-3 group" data-track="kontakt-whatsapp-frankfurt">
            <div class="shrink-0 flex h-11 w-11 items-center justify-center rounded-xl bg-emerald-50 text-emerald-dark">
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12.04 2c-5.46 0-9.91 4.45-9.91 9.91 0 1.75.46 3.45 1.32 4.95L2.05 22l5.25-1.38a9.9 9.9 0 0 0 4.74 1.21h.01c5.46 0 9.91-4.45 9.91-9.91A9.9 9.9 0 0 0 19.05 4.9 9.9 9.9 0 0 0 12.04 2zm0 18.13a8.2 8.2 0 0 1-4.18-1.14l-.3-.18-3.11.82.83-3.03-.19-.31a8.21 8.21 0 0 1-1.26-4.38c0-4.54 3.69-8.23 8.23-8.23 2.2 0 4.27.86 5.82 2.41a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.23-8.25 8.23zm4.51-6.16c-.25-.12-1.46-.72-1.68-.81-.23-.08-.39-.12-.55.12-.16.25-.64.81-.78.97-.14.16-.29.18-.54.06-.25-.12-1.04-.38-1.99-1.22-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.02-.39.11-.51.11-.11.25-.29.38-.43.12-.14.16-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.55-1.33-.76-1.82-.2-.48-.4-.41-.55-.42l-.47-.01a.9.9 0 0 0-.66.31c-.23.25-.86.85-.86 2.06s.89 2.39 1.01 2.56c.12.17 1.74 2.66 4.22 3.73 1.48.64 2.06.69 2.8.58.45-.07 1.46-.6 1.66-1.18.21-.58.21-1.08.14-1.18-.06-.1-.23-.16-.48-.28z"/></svg>
            </div>
            <div>
              <div class="text-xs font-medium uppercase tracking-wider text-slate-mute">WhatsApp</div>
              <div class="text-lg font-semibold text-ink-950 group-hover:text-emerald transition">{site.whatsapp}</div>
            </div>
          </a>

          <div class="flex items-start gap-3">
            <div class="shrink-0 flex h-11 w-11 items-center justify-center rounded-xl bg-emerald-50 text-emerald-dark">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
            </div>
            <div>
              <div class="text-xs font-medium uppercase tracking-wider text-slate-mute">E-Mail</div>
              <a href={`mailto:${site.email}`} class="text-lg font-semibold text-ink-950 hover:text-emerald transition">{site.email}</a>
            </div>
          </div>

          <div class="flex items-start gap-3">
            <div class="shrink-0 flex h-11 w-11 items-center justify-center rounded-xl bg-emerald-50 text-emerald-dark">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0zM15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            </div>
            <div>
              <div class="text-xs font-medium uppercase tracking-wider text-slate-mute">Einsatzgebiet</div>
              <div class="text-sm sm:text-base text-ink-950 break-words">Frankfurt am Main · Offenbach · Mainz · Wiesbaden · Darmstadt</div>
              <div class="text-xs text-slate-mute mt-0.5">Hauptsitz: {site.street}, {site.zip} {site.city}</div>
            </div>
          </div>
        </div>
      </div>

      <div class="lg:col-span-7">
        <form
          name="frankfurt-anfrage"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          action="/danke/"
          class="rounded-3xl bg-white ring-1 ring-slate-border p-6 sm:p-10 shadow-card"
        >
          <input type="hidden" name="form-name" value="frankfurt-anfrage" />
          <input type="hidden" name="source" value="kontaktformular" />
          <p class="hidden"><label>Bot Feld: <input name="bot-field" /></label></p>

          <h3 class="text-xl font-bold text-ink-950">Anfrage für Frankfurt</h3>
          <p class="mt-1 text-sm text-slate-mute">Pflichtfelder sind mit * markiert. Wir antworten innerhalb von 24 Stunden.</p>

          <div class="mt-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="sm:col-span-2">
              <label for="fk-name" class="block text-xs font-medium text-slate-mute mb-1.5">Name *</label>
              <input id="fk-name" name="name" type="text" required minlength="2" placeholder="Vor- und Nachname" class="input-light" autocomplete="name" />
            </div>
            <div>
              <label for="fk-email" class="block text-xs font-medium text-slate-mute mb-1.5">E-Mail *</label>
              <input id="fk-email" name="email" type="email" required placeholder="kontakt@firma.de" class="input-light" autocomplete="email" />
            </div>
            <div>
              <label for="fk-tel" class="block text-xs font-medium text-slate-mute mb-1.5">Telefon *</label>
              <input id="fk-tel" name="telefon" type="tel" required placeholder="069 12345678" class="input-light" autocomplete="tel" />
            </div>
            <div class="sm:col-span-2">
              <label for="fk-leistung" class="block text-xs font-medium text-slate-mute mb-1.5">Gewünschte Leistung</label>
              <div class="relative">
                <select id="fk-leistung" name="leistung" class="input-light !pr-10 cursor-pointer appearance-none bg-white">
                  <option value="">Bitte wählen…</option>
                  {FRANKFURT_FORM_SERVICES.map((s) => (
                    <option value={s}>{s}</option>
                  ))}
                </select>
                <svg class="pointer-events-none absolute right-4 top-1/2 -translate-y-1/2 h-5 w-5 text-slate-mute" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 8 4 4 4-4" stroke-linecap="round" stroke-linejoin="round" /></svg>
              </div>
            </div>
            <div>
              <label for="fk-groesse" class="block text-xs font-medium text-slate-mute mb-1.5">Objektgröße (m²)</label>
              <input id="fk-groesse" name="groesse" type="number" min="0" placeholder="z. B. 250" class="input-light" />
            </div>
            <div>
              <label for="fk-plz" class="block text-xs font-medium text-slate-mute mb-1.5">PLZ Objekt</label>
              <input id="fk-plz" name="plz" type="text" placeholder="z. B. 60311" class="input-light" autocomplete="postal-code" />
            </div>
            <div class="sm:col-span-2">
              <label for="fk-msg" class="block text-xs font-medium text-slate-mute mb-1.5">Nachricht</label>
              <textarea id="fk-msg" name="nachricht" rows="4" placeholder="Beschreiben Sie kurz das Objekt und die gewünschte Reinigung." class="input-light resize-none"></textarea>
            </div>
          </div>

          <div class="mt-5 flex items-start gap-2">
            <input id="fk-consent" type="checkbox" name="datenschutz" required class="mt-1 h-4 w-4 rounded accent-emerald" />
            <label for="fk-consent" class="text-xs text-slate-mute">
              Ich stimme der Verarbeitung meiner Daten gemäß <a href="/datenschutz" class="text-emerald hover:underline font-medium">Datenschutz</a> zu. *
            </label>
          </div>

          <button type="submit" class="mt-6 btn-primary w-full sm:w-auto" data-track="form-frankfurt-kontakt">
            Anfrage absenden
            <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
          </button>
        </form>
      </div>

    </div>
  </div>
</section>
